# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME="HealthCare Production AI Agent"
APP_VERSION="1.0.0"

# LLM
OPENAI_API_KEY=""
LLM_MODEL="gpt-4o-mini"

# Security
AGENT_API_KEY="dev-key-change-me"
ALLOWED_ORIGINS="*"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Budget
DAILY_BUDGET_USD=10.0

# Storage
REDIS_URL=redis://localhost:6379/0
